.fade-scale-element {
    transition: opacity 0.4s ease-out-cubic, scale 0.4s ease-out-cubic;
}

.fade-scale-hidden {
    opacity: 0;
    scale: 0.8 0.8;
}

.fade-scale-visible {
    opacity: 1;
    scale: 1 1;
}

.screen-fader {
    position: absolute;
    width: 100%;
    height: 100%;
    background-color: rgb(0, 0, 0);
    transition: opacity 0.6s ease-in-out;
}

.fader-hidden {
    opacity: 0;
    display: none;
}

.fader-visible {
    opacity: 1;
    display: flex;
}
