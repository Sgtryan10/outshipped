.start {
    width: 598.898px;
    height: 46.784px;
    align-items: center;
    align-self: center;
    position: relative;
    -unity-background-scale-mode: stretch-to-fill;
    opacity: 0;
    transition-property: opacity;
    transition-duration: 0.5s;
    transition-timing-function: ease-in-out;
}

.start-visible {
    opacity: 1;
}

.start-dimmed {
    opacity: 0;
}

.fade-out {
    opacity: 0;
    transition-duration: 0.75s;
}

.fade-in {
    opacity: 1;
    transition-duration: 0.75s;
}
