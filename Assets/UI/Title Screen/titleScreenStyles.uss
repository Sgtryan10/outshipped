}

.curtain-parent-start {
    overflow: hidden;
    height: 0px;
    transition-property: height;
    transition-duration: 0.25s;
    transition-timing-function: ease-out-sine;
    width: 636px;
    display: flex;
    visibility: visible;
    flex-shrink: 0;
    flex-grow: 0;
}

