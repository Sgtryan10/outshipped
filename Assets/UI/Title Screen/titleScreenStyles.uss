.outline-start {
    scale: 1 0;
    transform-origin: center;
    transition-property: scale;
    transition-duration: 0.75s;
    flex-grow: 1;
    align-items: center;
    align-content: center;
    align-self: center;
    -unity-background-scale-mode: scale-to-fit;
    max-height: none;
    -unity-slice-type: sliced;
    width: 1745.072px;
    height: 896.7279px;
}

.outline-end {
    scale: 1 1;
}

.curtain-parent-courier {
    overflow: hidden;
    height: 41.472px;
    transition-property: width;
    transition-duration: 0.25s;
    transition-timing-function: ease-out-sine;
    width: 0;
    display: flex;
    visibility: visible;
}

.curtain-parent-courier-open {
    width: 477.203px;
}

.courier-anim {
    position: absolute;
    top: 0;
    left: 0;
    width: 477.203px;
    height: 41.472px;
}

.curtain-parent-os {
    overflow: hidden;
    height: 19.493px;
    transition-property: width;
    transition-duration: 0.25s;
