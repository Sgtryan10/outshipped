            <ui:VisualElement name="BottomBar" class="bottom-bar bottom-bar-reveal" style="background-image: url(&quot;project://database/Assets/UI/Selection%20Screen/Textures/selectionScreenBottomBar.svg?fileID=7388822144124034973&amp;guid=55208653e051550748707f4550f8ea25&amp;type=3#selectionScreenBottomBar&quot;);"/>
