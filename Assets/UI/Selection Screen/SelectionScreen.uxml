                    <ui:VisualElement name="MonarchDescription" class="monarch-description hover-monarch-description" style="flex-grow: 1; background-image: url(&quot;project://database/Assets/UI/Selection%20Screen/Textures/selectionScreenMonarchDescription.svg?fileID=7388822144124034973&amp;guid=0d0a0176fa03394a2b5c5f65390ae425&amp;type=3#selectionScreenMonarchDescription&quot;);"/>
